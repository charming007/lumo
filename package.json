{
  "name": "lumo-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:lms": "npm --workspace apps/lms-web run dev",
    "dev:api": "npm --workspace services/api run start:dev",
    "build:lms": "npm --workspace apps/lms-web run build",
    "build:api": "npm --workspace services/api run build"
  }
}
