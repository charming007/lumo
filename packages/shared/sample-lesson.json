          "id": "apple",
          "label": "Apple",
          "isCorrect": true,
          "media": { "kind": "image", "value": "apple" }
        },
        {
          "id": "ball",
          "label": "Ball",
          "media": { "kind": "image", "value": "ball" }
        },
        {
          "id": "sun",
          "label": "Sun",
          "media": { "kind": "image", "value": "sun" }
        }
      ],
      "successFeedback": "Yes. Apple starts with /a/.",
      "retryFeedback": "Listen again. Which word starts with /a/?"
