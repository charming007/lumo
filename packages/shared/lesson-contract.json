{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lumo Lesson Contract",
  "type": "object",
  "required": ["id", "subject", "title", "mode", "activitySteps"],
  "properties": {
    "id": { "type": "string" },
    "subject": { "type": "string", "enum": ["english", "math", "life-skills"] },
    "title": { "type": "string" },
    "mode": { "type": "string", "enum": ["guided", "independent", "group", "practice"] },
    "targetAgeRange": { "type": ["string", "null"] },
    "voicePersona": { "type": ["string", "null"] },
    "durationMinutes": { "type": ["number", "null"] },
    "learningObjectives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "localization": {
      "type": ["object", "null"],
      "properties": {
        "locale": { "type": ["string", "null"] },
        "supportLanguage": { "type": ["string", "null"], "enum": ["ha", null] },
        "supportLanguageLabel": { "type": ["string", "null"] },
        "targetLanguage": { "type": ["string", "null"], "enum": ["en", null] },
        "targetLanguageLabel": { "type": ["string", "null"] },
        "defaultStepSupportText": { "type": ["string", "null"] },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "lessonAssessment": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "activitySteps": {
      "type": "array",
      "items": { "$ref": "#/$defs/activityStep" }
    },
    "activities": {
      "description": "Backward-compatible alias of activitySteps.",
      "type": "array",
      "items": { "$ref": "#/$defs/activityStep" }
    }
  },
  "$defs": {
    "activityStep": {
      "type": "object",
      "required": ["id", "type", "prompt"],
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "integer", "minimum": 1 },
        "type": {
          "type": "string",
          "enum": [
            "letter_intro",
            "listen_repeat",
            "image_choice",
            "speak_answer",
            "word_build",
            "tap_choice",
            "drag_to_match",
            "listen_answer",
            "oral_quiz"
          ]
        },
        "prompt": { "type": "string" },
        "hint": { "type": "string" },
        "targetText": { "type": "string" },
        "supportText": { "type": "string" },
        "expectedAnswers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "isCorrect": { "type": "boolean" },
              "media": {
                "type": "object",
                "properties": {
                  "kind": { "type": "string" },
                  "value": {}
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "dragItems": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "targetId"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "targetId": { "type": "string" },
              "media": {
                "type": "object",
                "properties": {
                  "kind": { "type": "string" },
                  "value": {}
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "dragTargets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "prompt"],
            "properties": {
              "id": { "type": "string" },
              "prompt": { "type": "string" },
              "media": {
                "type": "object",
                "properties": {
                  "kind": { "type": "string" },
                  "value": {}
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "value": {}
            },
            "required": ["kind", "value"],
            "additionalProperties": true
          }
        },
        "successFeedback": { "type": "string" },
        "retryFeedback": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  }
}
